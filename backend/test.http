###管理者ログイン（トークン取得）
POST http://localhost:8080/api/login
Content-Type: application/json

{
"email": "admin@example.com",
"password": "password000"
}

> {%
const body = JSON.parse(response.body);
%}

###カテゴリ作成（任意、存在しない場合）
POST http://localhost:8080/api/categories
Content-Type: application/json
Authorization: Bearer {{login.response.body.$.token}}

{
"name": "E2E Category",
"description": "自動作成カテゴリ"
}

###商品追加（POST /api/products）
POST http://localhost:8080/api/products
Content-Type: application/json
Authorization: Bearer {{login.response.body.$.token}}

{
"name": "テスト商品 E2E",
"price": 1500,
"is_available": true,
"category_id": 1,
"sku": "E2E-SKU-20260304-001",
"description": "E2Eテスト用の商品説明",
"image_url": "https://example.com/image.jpg",
"stock_quantity": 20
}

###商品削除（DELETE /api/products/:id）
DELETE http://localhost:8080/api/products/<PRODUCT_ID>
Authorization: Bearer <ADMIN_TOKEN>


###ログイン->カート追加->注文作成->注文一覧->注文キャンセル->キャンセル後一覧確認
@baseUrl = http://localhost:8080
@email = kimura@example.com
@password = password000
@productId = 4

#### 0. ユーザ登録
POST {{baseUrl}}  /api/register
Content-Type: application/json

{
    "name": "木村　次郎",
    "email": "{{email}}",
    "password": "{{password}}"
}

#### 1. ログインしてトークン保存
# @name login
POST {{baseUrl}}/api/login
Content-Type: application/json

{
    "email": "{{email}}",
    "password": "{{password}}"
}

> {%
const body = JSON.parse(response.body);
%}

### 2. カートに商品追加
POST {{baseUrl}}/api/cart/items
Content-Type: application/json
Authorization: Bearer {{login.response.body.$.token}}

{
  "product_id": {{productId}},
  "quantity": 2
}

#### 3. 注文作成
# @name order
POST {{baseUrl}}/api/orders
Content-Type: application/json
Authorization: Bearer {{login.response.body.$.token}}

{}

> {%
const body = JSON.parse(response.body);
%}

### 4. 注文一覧確認
GET {{baseUrl}}/api/orders
Authorization: Bearer {{login.response.body.$.token}}

### 5. 作成した注文をキャンセル
POST {{baseUrl}}/api/orders/{{order.response.body.$.order.id}}/cancel
Content-Type: application/json
Authorization: Bearer {{login.response.body.$.token}}

{}

### 6. 全ての注文一覧確認
GET {{baseUrl}}/api/orders
Authorization: Bearer {{login.response.body.$.token}}

### 7. キャンセル済みだけ確認
GET {{baseUrl}}/api/orders?status=cancelled
Authorization: Bearer {{login.response.body.$.token}}

