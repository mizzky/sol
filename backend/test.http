"image_url": "https://example.com/image.jpg",
"stock_quantity": 20
}

###商品削除（DELETE /api/products/:id）
DELETE http://localhost:8080/api/products/<PRODUCT_ID>
Authorization: Bearer <ADMIN_TOKEN>