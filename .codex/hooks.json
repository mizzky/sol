{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$(git rev-parse --show-toplevel)/.agents/skills/studylog/scripts/auto-checkpoint.sh\"",
            "timeout": 30,
            "statusMessage": "Saving transcript before compaction"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$(git rev-parse --show-toplevel)/.agents/skills/studylog/scripts/auto-checkpoint.sh\"",
            "timeout": 30,
            "statusMessage": "Saving transcript checkpoint"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$(git rev-parse --show-toplevel)/.agents/skills/studylog/scripts/auto-checkpoint.sh\"",
            "timeout": 30,
            "statusMessage": "Saving prompt checkpoint"
          }
        ]
      }
    ]
  }
}
